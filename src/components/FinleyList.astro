---
import Group from "../layouts/Group.astro";
import type { Link } from "../types/link";

type Props = {
  links: Link[];
};

const { links } = Astro.props;
---

<ul>
  <Group gap={"1.25em"} alignItems={"center"}>
    {
      links.map((link) => (
        <li>
          <a href={link.href}>{link.title}</a>
        </li>
      ))
    }
  </Group>
</ul>
<style>
  ul {
    padding: 0;
    font-size: 2em;
  }

  li {
    font-weight: 900;
    list-style-type: none;
  }

  a {
    position: relative;
    color: inherit;
    text-decoration: none;
    text-align: center;
  }

  a::before {
    transition:
      opacity 0.25s ease-in-out,
      margin-right 0.25s ease-in-out,
      transform 0.25s ease-in-out;
    transform: scale(0.5);
    /* transform-origin: left center; */
    opacity: 0;
    /* overflow: hidden; */
    content: "►";
    position: absolute;
    right: 100%;
    margin-right: 48pt;
    font-size: 1em;
    align-self: center;
    justify-self: center;
    padding-top: 0.1em;
  }

  a:hover::before {
    opacity: 1;
    margin-right: 16pt;
    text-align: end;
    transform: scale(1);
  }
</style>
