---
// src/components/VimeoEmbed.astro
type Props = {
  id: string; // The numeric ID from your Vimeo URL
};

const { id } = Astro.props;
---

<div class="video-wrapper">
  <iframe
    src={`https://vimeo.com/1202937667`}
    width="640"
    height="360"
    frameborder="0"
    allow="autoplay; fullscreen; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style>
  /* Keeps the video aspect ratio responsive (16:9) */
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    padding-top: 0;
    height: 0;
    width: 100%;
    max-width: 800px; /* Limits max width so it doesn't overpower the screen */
    margin: 0 auto 2em auto; /* Centers it and adds space below */
    border-radius: 8px;
    overflow: hidden;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
</style>