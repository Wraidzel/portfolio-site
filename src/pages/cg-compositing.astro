---
// src/pages/cg-compositing.astro
import Content from "../layouts/Content.astro";
import FinleyPage from "../layouts/FinleyPage.astro";
import Group from "../layouts/Group.astro";

// 🎞️ RE-ADDED: Explicit imports for the TOP Video Reel Slideshow
import thumb1 from "../../public/reel-thumb-1.jpg";
import thumb2 from "../../public/reel-thumb-2.jpg";
import thumb3 from "../../public/reel-thumb-3.jpg";
import thumb4 from "../../public/reel-thumb-4.jpg";
import thumb5 from "../../public/reel-thumb-5.jpg";

// 🧸 Explicit imports for the BOTTOM Toppled Toybox Slideshow
import toybox1 from "../../public/toybox-thumb-1.jpg";
import toybox2 from "../../public/toybox-thumb-2.jpg";
import toybox3 from "../../public/toybox-thumb-3.jpg";
import toybox4 from "../../public/toybox-thumb-4.jpg";
import toybox5 from "../../public/toybox-thumb-5.jpg";
---

<FinleyPage>
  <Content>
    <Group alignItems="center">
      
      <div id="reel-container" class="video-container placeholder-active">
        
        <button id="play-trigger" class="video-placeholder" aria-label="Play CG & Compositing Reel">
          
          <div class="slideshow-background">
            <div class="slide slide-1" style={`background-image: url('${thumb1.src}')`}></div>
            <div class="slide slide-2" style={`background-image: url('${thumb2.src}')`}></div>
            <div class="slide slide-3" style={`background-image: url('${thumb3.src}')`}></div>
            <div class="slide slide-4" style={`background-image: url('${thumb4.src}')`}></div>
            <div class="slide slide-5" style={`background-image: url('${thumb5.src}')`}></div>
          </div>

          <div class="placeholder-content">
            <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <h2>CG & Compositing Reel <span class="subtext">(click here)</span></h2>
          </div>
        </button>

        <div id="video-target" class="video-iframe-wrapper"></div>
      </div>

      <div class="credits-section">
        <h3 class="credits-title">Notable Credits</h3>
        <ul class="credits-list">
          <li><strong>Love Story (2026)</strong> &ndash; Compositor, QC</li>
          <li><strong>The Beauty (2026)</strong> &ndash; Compositor, QC</li>
          <li><strong>Beast Games, Season 2 (2026)</strong> &ndash; Compositor, QC</li>
          <li><strong>Carved (2023)</strong> &ndash; CG Artist, Compositor</li>
        </ul>
        
        <div class="imdb-link-wrapper">
          <a href="https://www.imdb.com/name/nm14745650/" target="_blank" rel="noopener noreferrer" class="imdb-link">
            View Full IMDb Filmography <span>→</span>
          </a>
        </div>
      </div>

      <div class="toybox-section">
        <div class="toybox-text">
          <h3 class="toybox-title">@toppled_toybox</h3>
          <p>
            When I'm not doing compositing work, I create short-form animated educational videos on my dedicated Instagram account, <strong>Toppled Toybox</strong>.
          </p>
          <a href="https://www.instagram.com/toppled_toybox/" target="_blank" rel="noopener noreferrer" class="toybox-link">
            follow on instagram
          </a>
        </div>

        <div class="toybox-slideshow">
          <div class="v-slide v-slide-1" style={`background-image: url('${toybox1.src}')`}></div>
          <div class="v-slide v-slide-2" style={`background-image: url('${toybox2.src}')`}></div>
          <div class="v-slide v-slide-3" style={`background-image: url('${toybox3.src}')`}></div>
          <div class="v-slide v-slide-4" style={`background-image: url('${toybox4.src}')`}></div>
          <div class="v-slide v-slide-5" style={`background-image: url('${toybox5.src}')`}></div>
          <div class="slideshow-overlay"></div>
        </div>
      </div>

      <div class="action-footer">
        <a href="/" class="back-button">
          back
        </a>
      </div>

    </Group>
  </Content>
</FinleyPage>

<script>
  const trigger = document.getElementById('play-trigger');
  const container = document.getElementById('reel-container');
  const target = document.getElementById('video-target');

  trigger?.addEventListener('click', () => {
    if (container && target) {
      container.classList.remove('placeholder-active');
      container.classList.add('video-active');

      target.innerHTML = `
        <iframe 
          src="https://player.vimeo.com/video/1202937667?badge=0&autopause=0&player_id=0&app_id=58479&autoplay=1" 
          frameborder="0" 
          allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" 
          referrerpolicy="strict-origin-when-cross-origin" 
          style="position:absolute; top:0; left:0; width:100%; height:100%; background: black;" 
          title="Finley Stein - CG and Comp Reel">
        </iframe >
      `;
      
      trigger.style.display = 'none';
    }
  });
</script>

<style>
  /* --- 🖥️ DESKTOP STYLES --- */
  .video-container {
    position: relative;
    width: 100%;
    margin: 0 auto 3rem auto;
    overflow: hidden;
    border-radius: 12px;
    transition: padding-bottom 0.4s ease, border-radius 0.4s ease, box-shadow 0.4s ease, max-width 0.4s ease;
  }

  .placeholder-active {
    max-width: 550px; 
    padding-bottom: 45%; 
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .video-active {
    max-width: 850px;
    padding-bottom: 53%; 
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    border-radius: 0px; 
  }

  .video-placeholder {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: #111116; 
    border: 2px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease-in-out;
    z-index: 10;
    overflow: hidden;
  }

  .video-placeholder:hover {
    border-color: rgba(255, 255, 255, 0.2);
    transform: scale(1.01);
  }

  /* Horizontal Slideshow Styles */
  .slideshow-background {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
    background: #111116;
  }

  .slideshow-background::after {
    content: "";
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(17, 17, 22, 0.35); 
    z-index: 2;
  }

  .slide {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background-size: cover;
    background-position: center;
    filter: grayscale(100%);
    opacity: 0;
    animation: fade 20s linear infinite both; 
  }

  .slide-1 { animation-delay: 0s; }
  .slide-2 { animation-delay: 4s; }
  .slide-3 { animation-delay: 8s; }
  .slide-4 { animation-delay: 12s; }
  .slide-5 { animation-delay: 16s; }

  .placeholder-content {
    position: relative;
    z-index: 3; 
    text-align: center;
    color: #ffffff;
    font-family: system-ui, sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .play-icon {
    width: 45px;
    height: 45px;
    margin-bottom: 0.5em;
    color: #ffffff;
    transition: transform 0.25s ease;
    opacity: 0.8;
  }

  .video-placeholder:hover .play-icon {
    transform: scale(1.15);
    opacity: 1;
  }

  .placeholder-content h2 {
    margin: 0;
    font-size: 1.35em;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .subtext {
    display: block;
    font-size: 0.75em;
    font-weight: 400;
    opacity: 0.6;
    margin-top: 0.4em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .video-iframe-wrapper {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
  }

  /* --- 📝 CREDITS & IMDB STYLES --- */
  .credits-section {
    width: 100%;
    max-width: 650px; 
    margin: 0 auto 5rem auto; 
    text-align: left;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .credits-title {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    border-bottom: 2px solid rgba(0, 0, 0, 0.1);
    padding-bottom: 0.5rem;
    color: inherit;
  }

  .credits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .credits-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .credits-list li:last-child {
    border-bottom: none;
  }

  .credits-list strong {
    font-weight: 700;
  }

  .imdb-link-wrapper {
    margin-top: 1.5rem;
  }

  .imdb-link {
    display: inline-flex;
    align-items: center;
    font-weight: 700;
    color: #000080;
    text-decoration: none;
    font-size: 1.1rem;
    transition: color 0.2s ease;
  }

  .imdb-link span {
    margin-left: 0.4rem;
    transition: transform 0.2s ease;
  }

  .imdb-link:hover {
    color: #0000ff;
    text-decoration: underline;
  }

  .imdb-link:hover span {
    transform: translateX(4px);
  }

  /* --- 🧸 TOPPLED TOYBOX SECTION --- */
  .toybox-section {
    width: 100%;
    max-width: 850px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px; 
    gap: 4rem;
    align-items: center;
    background: rgba(0,0,0,0.02);
    padding: 3rem;
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,0.05);
  }

  .toybox-text {
    font-family: system-ui, -apple-system, sans-serif;
  }

  .toybox-title {
    font-family: "Futura-Medium", "Futura", system-ui, sans-serif;
    font-size: 2rem;
    margin: 0 0 1rem 0;
    color: #111;
  }

  .toybox-text p {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 1.75rem;
    color: #444;
  }

  .toybox-link {
    display: inline-block;
    font-family: "Futura-Medium", "Futura", system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 900;
    color: #111111;
    text-decoration: none;
    padding: 0.25rem 0rem;
    border-bottom: 2px solid #111111; 
    transition: opacity 0.2s ease;
  }

  .toybox-link:hover {
    opacity: 0.6;
  }

  /* Vertical Slideshow Formatting */
  .toybox-slideshow {
    position: relative;
    width: 100%;
    padding-bottom: 125%; 
    border-radius: 12px;
    overflow: hidden;
    background: #111;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
  }

  .slideshow-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(17, 17, 22, 0.15); 
    z-index: 2;
    pointer-events: none;
    transition: background 0.4s ease;
  }

  .toybox-slideshow:hover .slideshow-overlay {
    background: rgba(17, 17, 22, 0.0);
  }

  .v-slide {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background-size: cover;
    background-position: center;
    filter: grayscale(100%); 
    opacity: 0;
    animation: fade 20s linear infinite both; 
    z-index: 1;
    transition: filter 0.4s ease;
  }

  .toybox-slideshow:hover .v-slide {
    filter: grayscale(0%);
  }

  .v-slide-1 { animation-delay: 0s; }
  .v-slide-2 { animation-delay: 4s; }
  .v-slide-3 { animation-delay: 8s; }
  .v-slide-4 { animation-delay: 12s; }
  .v-slide-5 { animation-delay: 16s; }

  /* Universal Shared Crossfade Keyframes */
  @keyframes fade {
    0%   { opacity: 0; }
    5%   { opacity: 1; }
    20%  { opacity: 1; }
    25%  { opacity: 0; }
    100% { opacity: 0; }
  }

  /* --- 🔙 BACK BUTTON STYLES --- */
  .action-footer {
    margin-top: 4rem;
    text-align: center;
  }

  .back-button {
    display: inline-block;
    font-family: "Futura-Medium", "Futura", system-ui, sans-serif; 
    font-size: 2em; 
    font-weight: 900; 
    color: inherit; 
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .back-button:hover {
    opacity: 0.7; 
  }

  /* --- 📱 MOBILE STYLES --- */
  @media (max-width: 768px) {
    .placeholder-active {
      max-width: 340px; 
      padding-bottom: 90%; 
    }

    .video-active {
      max-width: 100%;
      padding-bottom: 53%; 
    }
    
    .credits-section {
      padding: 0 1rem; 
      margin-bottom: 3rem;
    }

    .credits-list {
      font-size: 1rem;
    }

    .toybox-section {
      grid-template-columns: 1fr; 
      padding: 2rem 1.5rem;
      gap: 2.5rem;
    }

    .toybox-link {
      margin-bottom: 1rem;
    }

    .toybox-slideshow {
      max-width: 300px; 
      margin: 0 auto;
    }

    .toybox-slideshow:active .v-slide {
      filter: grayscale(0%);
    }

    .action-footer {
      margin-top: 3.5rem;
    }
  }
</style>